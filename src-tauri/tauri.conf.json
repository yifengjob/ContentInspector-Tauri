{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ContentInspector",
  "version": "../package.json",
  "identifier": "com.content.inspector",
  "build": {
    "beforeDevCommand": "pnpm --filter content-inspector-frontend dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter content-inspector-frontend build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "ContentInspector - 内容审查官",
        "width": 1024,
        "height": 768,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "publisher": "YiFeng",
    "copyright": "Copyright © 2026 YiFeng",
    "category": "DeveloperTool",
    "shortDescription": "内容审查工具",
    "longDescription": "内容审查官 - 一款强大的本地内容搜索与审查工具",
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      },
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "allowDowngrades": true,
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese"]
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libappindicator3-1"],
        "files": {}
      }
    }
  }
}
